FLASK_ENV=production
FLASK_DEBUG=0
HOST_SERVER=https://zerotouchalgo.com
REDIRECT_URL=https://zerotouchalgo.com/auth/callback

# Broker API credentials (REQUIRED — replace with real values)
BROKER_API_KEY=your_broker_api_key_here
BROKER_API_SECRET=your_broker_api_secret_here
APP_KEY=change_me_to_a_random_secret_key_at_least_32_chars

# Database
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=changeme_redis_pass
SQLITE_PATH=/home/ubuntu/foss-universe/data/db/foss_trades.db

# Performance tuning
OPENBLAS_NUM_THREADS=2
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
NUMEXPR_NUM_THREADS=2
NUMBA_NUM_THREADS=2
STRATEGY_MEMORY_LIMIT_MB=1024

# Security
CORS_ORIGINS=*

# Cloudflare DDNS (optional — for dynamic IP VPS)
CF_API_TOKEN=your_cloudflare_api_token_here
CF_ZONE_ID=your_cloudflare_zone_id_here
RECORD_NAME=zerotouchalgo.com
